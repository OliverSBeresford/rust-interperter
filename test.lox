class A {
    var a = "A";

    method() {
        print "Method A";
    }
}
class B < A {
    init() {
        print "Init B";
        print super.a;
    }

    method() {
        print "Method B";
    }
    test() {
        super.method();
    }
}
class C < B {
    init() {
        super.init();
        print "Init C";
    }
}
C().test();