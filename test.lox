class A {
    var a = "A";

    method() {
        print "Method A";
    }
}
class B < A {
    init() {
        this.thing = "Init B";
        print super.a;
    }

    method() {
        print "Method B";
    }
    test() {
        return super.method();
    }
}
class C < B {
    init() {
        super.init();
        print this.thing;
        print "Init C";
    }
}
print C().test();

while (true) {
    print "Looping";
    if (1 == 1) {
        break;
    }
}